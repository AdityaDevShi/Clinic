rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // =========================================================================
    // HELPER FUNCTIONS
    // =========================================================================

    // Check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if the authenticated user has the 'admin' role
    function isAdmin() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Check if the authenticated user is accessing their own document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Check if the authenticated user has the 'therapist' role
    function isTherapist() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'therapist';
    }

    // =========================================================================
    // COLLECTION RULES
    // =========================================================================

    // 1. Users Collection
    match /users/{userId} {
      // Anyone can read their own profile, Admins can read all profiles
      allow read: if isOwner(userId) || isAdmin();
      
      // Updates are only allowed by the owner (excluding role) or by Admins
      // Users cannot change their own role parameter.
      allow update: if (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['role'])) || isAdmin();
      
      // Document creation/deletion is restricted to Server/Admin SDK only
      // New users are created securely via /api/auth/register-profile
      allow create, delete: if false; 
    }

    // 2. Therapists Collection
    match /therapists/{therapistId} {
      // Therapist profiles are public for the booking/listing pages
      allow read: if true;
      
      // Only the therapist themselves can update their profile, or an Admin
      allow update: if isOwner(therapistId) || isAdmin();
      
      // Only Admins (or Server SDK) can create/delete therapist profiles
      allow create, delete: if isAdmin();
    }

    // 3. Bookings/Appointments Collection
    match /bookings/{bookingId} {
      // Users can only read their own bookings. Therapists can read bookings assigned to them.
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.clientId || 
        request.auth.uid == resource.data.therapistId || 
        isAdmin()
      );
      
      // Creating a booking requires authentication and setting the clientId to themselves
      allow create: if isAuthenticated() && request.resource.data.clientId == request.auth.uid;
      
      // Updating a booking (e.g., status) depends on the role
      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.clientId || 
        request.auth.uid == resource.data.therapistId || 
        isAdmin()
      );
      
      // Only Admins can delete bookings
      allow delete: if isAdmin();
    }

    // 4. OTP Verifications Collection
    match /otp_verifications/{email} {
      // No client access. 
      // OTPs are strictly managed by the Server Admin SDK.
      allow read, write: if false;
    }

    // 5. Contact Submissions Collection
    match /contact_submissions/{docId} {
      // Managed by backend API only
      allow read, write: if false; 
    }

    // 6. Settings Collection (workshop banner, site config)
    // Public read so WorkshopBanner can display on every page
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 7. Availability Collection (therapist schedule)
    // Public read so booking pages can show available slots
    match /availability/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // 8. Busy Slots Collection (therapist blocked times)
    // Public read so booking pages can exclude busy times
    match /busy_slots/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // 9. Feedback Collection (client reviews)
    // Public read for therapist profile reviews
    match /feedback/{docId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // 10. Consents Collection (TOS consent records)
    // Only the admin SDK writes these, but allow authenticated create as fallback
    match /consents/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // 11. Patient Notes Collection (therapist session notes)
    match /patient_notes/{noteId} {
      // Therapist who created the note can read/write/delete
      allow read, write, delete: if isAuthenticated() &&
        request.auth.uid == resource.data.therapistId;
      // Allow create if therapistId in the new doc matches the current user
      allow create: if isAuthenticated() &&
        request.resource.data.therapistId == request.auth.uid;
      // Allow the patient (client) to read notes about them
      allow read: if isAuthenticated() &&
        request.auth.uid == resource.data.clientId;
    }

    // 12. Patient Attachments Collection (therapist uploaded files metadata)
    match /patient_attachments/{attachmentId} {
      allow read, write, delete: if isAuthenticated() &&
        request.auth.uid == resource.data.therapistId;
      allow create: if isAuthenticated() &&
        request.resource.data.therapistId == request.auth.uid;
      allow read: if isAuthenticated() &&
        request.auth.uid == resource.data.clientId;
    }

    // 13. Session Links Collection (Google Meet links per therapist-patient pair)
    match /session_links/{linkId} {
      allow read, write: if isAuthenticated() &&
        request.auth.uid == resource.data.therapistId;
      allow create: if isAuthenticated() &&
        request.resource.data.therapistId == request.auth.uid;
      // Allow the patient to read their session link
      allow read: if isAuthenticated() &&
        request.auth.uid == resource.data.clientId;
    }

    // 14. Arambh Expenses Collection (admin-only business expense tracking)
    match /arambh_expenses/{expenseId} {
      allow read, write, create, delete: if isAdmin();
    }

    // 15. Blog Posts Collection
    match /blog_posts/{postId} {
      allow read: if true;
      allow create: if isAuthenticated() && (isAdmin() || isTherapist());
      allow update: if isAuthenticated() && (isAdmin() || request.auth.uid == resource.data.authorId);
      allow delete: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.authorId);

      // Blog Comments Subcollection
      match /blog_comments/{commentId} {
        allow read: if true;
        allow create: if isAuthenticated();
        allow delete: if isAdmin();
      }

      // Blog Likes Subcollection
      match /blog_likes/{likeId} {
        allow read: if true;
        allow create: if isAuthenticated();
        allow delete: if isAuthenticated() && request.auth.uid == likeId;
      }
    }

    // 16. Manual Patients Collection (pre-existing patients added by therapists)
    match /manual_patients/{patientId} {
      // Therapist who created the record can read/update/delete
      allow read, write, delete: if isAuthenticated() &&
        request.auth.uid == resource.data.therapistId;
      // Allow create if therapistId in the new doc matches the current user
      allow create: if isAuthenticated() &&
        request.resource.data.therapistId == request.auth.uid;
      // Admin can access all
      allow read, write, delete: if isAdmin();
    }

    // 17. Generic Fallback
    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
